# No deployer private key here on purpose — the deploy script takes its
# broadcaster from an encrypted Foundry keystore (`cast wallet import`),
# never a plaintext env var. See "Deploying" in contracts/README.md.

MONAD_RPC_URL=https://rpc.monad.xyz
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# Source verification on deploy (forge script --verify), via Etherscan V2's
# multichain API, which also serves monadscan.com. Free tier: https://etherscan.io/apis
ETHERSCAN_API_KEY=
