# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Wallet connect (RainbowKit)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Monad mainnet (chain 143)
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://monadscan.com

# Monad testnet (chain 10143) — used for staging
NEXT_PUBLIC_MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_TESTNET_EXPLORER_URL=https://testnet.monadexplorer.com

# Horizon worker (Railway) — WebSocket RPC, separate from the HTTP RPC above.
# 143 = Monad mainnet (default target). Set 10143 for testnet staging.
HORIZON_CHAIN_ID=143
HORIZON_WS_RPC_URL=
HORIZON_WS_RPC_URL_FALLBACK=
LOGS_CHUNK_BLOCKS=500
HORIZON_WINDOW_BLOCKS=50
HORIZON_CONFIRMATION_DEPTH=3
HORIZON_WINDOW_FLUSH_MS=30000
HORIZON_WALLET_REFRESH_MS=60000
MERIDIAN_APP_URL=https://your-app.vercel.app

# Cron fallback (POST /api/horizon/sweep, x-horizon-secret header auth)
HORIZON_SWEEP_SECRET=
HORIZON_SWEEP_MAX_BLOCKS=5000

# Notifications (Notify/Confirm tier email on Moment creation; skipped for
# any wallet without a notification_email set — see Guardrails screen)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Meridian <onboarding@resend.dev>

# Price cache (USD normalization for R2 velocity + Horizon outflow_usd)
# Optional: without it, CoinGecko's public tier (5-15 req/min, unreliable)
# is used. A free Demo key (100 req/min, no billing) is recommended:
# https://support.coingecko.com/hc/en-us/articles/21880397454233
COINGECKO_API_KEY=

# Oracle explanation layer (POST /api/oracle/explain, x-oracle-secret header auth)
ANTHROPIC_API_KEY=
ORACLE_EXPLAIN_SECRET=

# Alarm-fatigue control: max moments created per wallet per UTC day, across
# all rules combined (per-rule dedup is separate, see pipeline.ts)
ORACLE_DAILY_MOMENT_CAP=10

# R4's explorer-verification lookup (Etherscan V2 multichain API, which
# serves monadscan.com). Optional: without it, verification status is
# "unknown" rather than "unverified" — never treated as a penalty either way.
# Free tier: https://etherscan.io/apis
ETHERSCAN_API_KEY=
